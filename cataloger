# ─────────────────────────────────────────────────────────────
# GitHub sync only (pull existing)
# ─────────────────────────────────────────────────────────────

def cmd_github_sync():
    if not GITHUB_DIR.exists():
        print("❌ No github-prod directory. Run: cataloger --add-github --token TOKEN")
        sys.exit(1)
    repos = [d for d in GITHUB_DIR.iterdir() if d.is_dir() and (d / ".git").exists()]
    if not repos:
        print("No repos in github-prod yet.")
        return
    print(f"🔄 Pulling {len(repos)} repos in {GITHUB_DIR}...")
    for repo in sorted(repos):
        r = subprocess.run(
            ["git", "-C", str(repo), "pull", "--ff-only"],
            capture_output=True, text=True
        )
        status = r.stdout.strip().split("\n")[0] if r.returncode == 0 else f"⚠ {r.stderr.strip()[:60]}"
        print(f"  {repo.name}: {status}")


# ─────────────────────────────────────────────────────────────
# Main dispatcher
# ─────────────────────────────────────────────────────────────

def main():
    # Show help
    if len(sys.argv) == 1 or sys.argv[1] in ("-h", "--help"):
        if len(sys.argv) == 1:
            # No args → run full scan via cataloger.py
            pass
        else:
            print(HELP)
            sys.exit(0)

    args = sys.argv[1:]

    # --add-github [--token TOKEN]
    if "--add-github" in args:
        token = None
        if "--token" in args:
            idx = args.index("--token")
            if idx + 1 < len(args):
                token = args[idx + 1]
            else:
                print("❌ --token requires a value")
                sys.exit(1)
        cmd_add_github(set_token=token)
        return

    # --set-token TOKEN
    if "--set-token" in args:
        idx = args.index("--set-token")
        if idx + 1 < len(args):
            token = args[idx + 1]
            cfg = load_config()
            cfg["github_token"] = token
            save_config(cfg)
        else:
            print("❌ --set-token requires a value")
            sys.exit(1)
        return

    # --github-sync
    if "--github-sync" in args:
        cmd_github_sync()
        return

    # All other commands → delegate to gitlab_wiki.py or cataloger.py
    wiki_script    = CATALOGER_DIR / "gitlab_wiki.py"
    catalog_script = CATALOGER_DIR / "cataloger.py"

    if any(a in args for a in ("--map", "--add-local", "--add-url", "--detect-integrations")):
        script = wiki_script

    elif len(args) == 1 and not args[0].startswith("-"):
        # cataloger project-name  →  rescan single project + update wiki page
        project_name = args[0]
        cmd_rescan_project(project_name)
        return

    else:
        # Default: full scan
        script = catalog_script

    os.execv(sys.executable, [sys.executable, str(script)] + args)


def cmd_rescan_project(project_name: str):
    """Rescan a single project and update wiki/projects/project-name.md"""
    import json as _json, re as _re

    # Find project path: LOCAL_ONLY_PROJECTS → search roots
    search_roots = [
        CATALOGER_DIR.parent,
        Path("/Users/andriy/gitlab-prod"),
        Path("/Users/andriy/github-prod"),
    ]

    local_only = {}
    wiki_script = CATALOGER_DIR / "gitlab_wiki.py"
    if wiki_script.exists():
        text = wiki_script.read_text()
        m = _re.search(r'LOCAL_ONLY_PROJECTS\s*=\s*\{([^}]+)\}', text, _re.DOTALL)
        if m:
            for line in m.group(1).splitlines():
                km = _re.search(r'"([^"]+)"\s*:\s*"([^"]+)"', line)
                if km:
                    local_only[km.group(1)] = km.group(2)

    project_path = None
    if project_name in local_only:
        p = Path(local_only[project_name])
        if p.exists():
            project_path = p

    if not project_path:
        for root in search_roots:
            c = root / project_name
            if c.exists() and c.is_dir():
                project_path = c
                break

    if not project_path:
        print(f"❌ Project '{project_name}' not found")
        print(f"   Add it with: cataloger --add-local /path/to/{project_name}")
        sys.exit(1)

    print(f"🔍 Rescanning: {project_name}  ({project_path})")

    # Use cataloger.py's ProjectScanner directly
    sys.path.insert(0, str(CATALOGER_DIR))
    import importlib.util
    spec = importlib.util.spec_from_file_location("cat", CATALOGER_DIR / "cataloger.py")
    cat = importlib.util.module_from_spec(spec)
    spec.loader.exec_module(cat)

    scanner = cat.ProjectScanner(project_path)
    meta = scanner.scan()

    # Update catalog_state.json
    state_file = CATALOGER_DIR / "catalog_state.json"
    state = {}
    if state_file.exists():
        try:
            state = _json.loads(state_file.read_text())
        except Exception:
            pass
    state[project_name] = meta
    state_file.write_text(_json.dumps(state, indent=2, default=str))
    print(f"   ✓ catalog_state.json updated")

    # Generate wiki page using WikiGenerator with single project
    wiki_dir = CATALOGER_DIR / "wiki" / "projects"
    wiki_dir.mkdir(parents=True, exist_ok=True)

    gen = cat.WikiGenerator({project_name: meta})
    # Temporarily redirect WIKI_DIR to our wiki dir
    original_wiki = cat.WIKI_DIR
    cat.WIKI_DIR = CATALOGER_DIR / "wiki"
    (CATALOGER_DIR / "wiki" / "projects").mkdir(parents=True, exist_ok=True)
    gen._gen_project_pages()
    cat.WIKI_DIR = original_wiki

    out = wiki_dir / f"{project_name}.md"
    if out.exists():
        print(f"   ✓ {out}")
    print(f"✅ Done: {project_name}")


if __name__ == "__main__":
    main()
