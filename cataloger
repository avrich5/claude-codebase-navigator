#!/usr/bin/env python3
"""
cataloger — unified CLI for project_cataloger
=============================================
Запускається з будь-якої папки: просто набери cataloger

КОМАНДИ:
  cataloger                    Повне сканування + wiki (cataloger.py)
  cataloger --map P1 P2        Карта проектів для Claude (gitlab_wiki.py)
  cataloger --add-local PATH   Додати локальний проект
  cataloger --add-github       Клонувати/оновити всі GitHub репо (avrich5)
  cataloger --add-url URL      Клонувати gitlab репо
  cataloger --github-sync      Тільки git pull у всіх github-prod проектах
  cataloger -h / --help        Ця довідка
"""

import sys
import os
import subprocess
import json
import argparse
from pathlib import Path

CATALOGER_DIR = Path(__file__).resolve().parent
GITHUB_DIR    = Path("/Users/andriy/github-prod")
CONFIG_FILE   = Path.home() / ".config" / "cataloger" / "config.json"

GITHUB_USER   = "avrich5"
GITHUB_API    = f"https://api.github.com/user/repos?per_page=100&type=all"

ENV_FILE = CATALOGER_DIR / ".env"


# ─────────────────────────────────────────────────────────────
# Config helpers
# ─────────────────────────────────────────────────────────────

def load_env() -> dict:
    """Parse .env file next to cataloger script."""
    env = {}
    if ENV_FILE.exists():
        for line in ENV_FILE.read_text().splitlines():
            line = line.strip()
            if not line or line.startswith("#") or "=" not in line:
                continue
            k, _, v = line.partition("=")
            env[k.strip()] = v.strip().strip('"').strip("'")
    return env


def load_config() -> dict:
    if CONFIG_FILE.exists():
        try:
            return json.loads(CONFIG_FILE.read_text())
        except Exception:
            pass
    return {}


def save_config(cfg: dict):
    CONFIG_FILE.parent.mkdir(parents=True, exist_ok=True)
    CONFIG_FILE.write_text(json.dumps(cfg, indent=2))
    print(f"✅ Config saved: {CONFIG_FILE}")


def get_github_token() -> str:
    """Token priority: env var → .env file → config file"""
    token = os.environ.get("GITHUB_TOKEN", "")
    if not token:
        token = load_env().get("GITHUB_TOKEN", "")
    if not token:
        cfg = load_config()
        token = cfg.get("github_token", "")
    return token


# ─────────────────────────────────────────────────────────────
# GitHub sync
# ─────────────────────────────────────────────────────────────

def cmd_add_github(set_token: str = None):
    """Clone / pull all repos from github.com/avrich5"""
    import urllib.request

    if set_token:
        cfg = load_config()
        cfg["github_token"] = set_token
        save_config(cfg)
        print(f"✅ GitHub token saved to {CONFIG_FILE}")

    token = get_github_token()
    if not token:
        print("❌ GitHub token not found.")
        print("   Set it once with:  cataloger --add-github --token ghp_xxxx")
        print("   Or export:         export GITHUB_TOKEN=ghp_xxxx")
        sys.exit(1)

    # Fetch repo list (includes private repos with token)
    req = urllib.request.Request(
        GITHUB_API,
        headers={
            "Authorization": f"token {token}",
            "Accept": "application/vnd.github.v3+json",
            "User-Agent": "cataloger/1.0",
        }
    )
    try:
        with urllib.request.urlopen(req, timeout=15) as resp:
            repos = json.loads(resp.read())
    except Exception as e:
        print(f"❌ GitHub API error: {e}")
        sys.exit(1)

    if isinstance(repos, dict) and repos.get("message"):
        print(f"❌ GitHub API: {repos['message']}")
        sys.exit(1)

    GITHUB_DIR.mkdir(parents=True, exist_ok=True)

    print(f"📦 Found {len(repos)} repos for {GITHUB_USER}")
    print()

    cloned, updated, skipped, failed = [], [], [], []

    for repo in repos:
        name     = repo["name"]
        ssh_url  = repo["ssh_url"]
        https_url = repo["clone_url"]
        private  = repo.get("private", False)
        archived = repo.get("archived", False)
        label    = "🔒 private" if private else "🌐 public"
        if archived:
            label += " [archived]"

        dest = GITHUB_DIR / name

        if dest.exists() and (dest / ".git").exists():
            # Pull existing
            print(f"  ↻  {name} ({label}) — pulling...")
            r = subprocess.run(
                ["git", "-C", str(dest), "pull", "--ff-only"],
                capture_output=True, text=True
            )
            if r.returncode == 0:
                msg = r.stdout.strip().split("\n")[0]
                updated.append(name)
                print(f"     ✓ {msg}")
            else:
                failed.append(name)
                print(f"     ⚠ {r.stderr.strip()[:80]}")
        else:
            # Clone — try SSH first, fallback to HTTPS with token
            print(f"  ➕ {name} ({label}) — cloning...")
            clone_url = f"https://{token}@github.com/{GITHUB_USER}/{name}.git"
            r = subprocess.run(
                ["git", "clone", "--depth=50", clone_url, str(dest)],
                capture_output=True, text=True
            )
            if r.returncode == 0:
                cloned.append(name)
                print(f"     ✓ cloned")
            else:
                failed.append(name)
                print(f"     ❌ {r.stderr.strip()[:120]}")

    print()
    print(f"✅ Done: {len(cloned)} cloned, {len(updated)} updated, {len(failed)} failed")
    if failed:
        print(f"   Failed: {', '.join(failed)}")

    # Register all in LOCAL_ONLY_PROJECTS via --add-local
    if cloned and (CATALOGER_DIR / "gitlab_wiki.py").exists():
        print()
        print("📝 Registering new repos in cataloger...")
        new_paths = [str(GITHUB_DIR / n) for n in cloned]
        subprocess.run(
            [sys.executable, str(CATALOGER_DIR / "gitlab_wiki.py"),
             "--add-local"] + new_paths
        )


